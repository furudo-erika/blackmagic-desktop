{
  "name": "@bm/daemon",
  "version": "0.4.50",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit && node scripts/bundle.mjs",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test --test-concurrency=1 src/**/*.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "gray-matter": "^4.0.3",
    "chokidar": "^4.0.1",
    "node-cron": "^3.0.3",
    "toml": "^3.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "esbuild": "^0.25.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
