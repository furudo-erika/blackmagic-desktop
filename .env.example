# Black Magic Desktop — environment overrides
#
# You do NOT need to set any of these in production. On first launch the
# app signs you in to blackmagic.run, drops a ck_ key at
# `~/BlackMagic/.bm/config.toml`, and uses api.blackmagic.run for all LLM
# + tool calls. The server holds every upstream secret.
#
# These variables are for dev work only — point the daemon at a local
# copy of the API, override the context path, etc.

# --- LLM / API proxy ---
#
# Default: https://api.blackmagic.run/api/v1  (the public proxy; ck_ auth)
# Override to point at a local dev server of blackmagic-ai:
# BM_API_URL=http://localhost:3001
# BM_BILLING_URL=http://localhost:3001
#
# NEVER put sk- / upstream keys here — those live only on the server.

# --- Local daemon ---
# BM_DAEMON_PORT=45781           # pin a fixed port (default: ephemeral)
# BM_CONTEXT_PATH=/path/to/context    # override context location
# BM_DEFAULT_MODEL=gpt-5.3-codex  # codex model ID

# --- Dev only: skip OAuth, paste a ck_ key directly ---
# ZENN_API_KEY=ck_your_dev_key_here
