# Zenn LLM provider (proxy to OpenAI Responses API)
ZENN_BASE_URL=https://zenn.engineering/api/v1
ZENN_API_KEY=ck_your_key_here

# Default codex model (see zenn docs)
BM_DEFAULT_MODEL=gpt-5.3-codex

# Daemon HTTP port (127.0.0.1 only)
BM_DAEMON_PORT=45781

# Vault path (override for testing; defaults to ~/BlackMagic)
# BM_VAULT_PATH=/path/to/vault

# Billing backend (blackmagic.run)
BM_BILLING_URL=https://blackmagic.run
# If unset, token events are logged locally only

# External tool keys (optional; only needed for specific tools)
PPLX_API_KEY=
PDL_API_KEY=
ENRICHLAYER_API_KEY=
APIFY_API_TOKEN=
RESEND_API_KEY=
